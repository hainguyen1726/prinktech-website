# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local scripts (one-time db seeds/updates)
insert-*.mjs
update-*.mjs
update-*.cjs
print-*.mjs
check-posts.mjs

# credentials & keys
*credentials*.json
*credential*.json
*key*.json
amazon-*.json

# scratch scripts & generated files
scratch/
bao_gia/
Bao_gia_in_tem_*.xlsx
Bao_gia_in_tem_*.pdf
